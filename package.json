{
  "name": "brep-io-kernel",
  "version": "1.0.0",
  "scripts": {
    "start": "pnpm dev",
    "dev": "node ./scripts/prepareFontAssets.js && pnpm prepareFonts && pnpm build:kernel && vite --host 0.0.0.0",
    "build": "pnpm prepareFonts && pnpm build:kernel && vite build",
    "build:cloudflare": "node ./scripts/buildCloudflare.js",
    "build:manifoldPlus": "node ./scripts/buildManifoldPlus.js",
    "build:kernel": "node ./scripts/prepareManifoldRuntime.js && pnpm generateLicenses && vite build --config vite.config.kernel.js && node ./scripts/syncKernelAssets.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "liveTesting": "nodemon --watch src --watch tests --ext js --exec \"pnpm test\"",
    "test": "node ./scripts/prepareManifoldRuntime.js && node ./src/tests/tests.js",
    "generateLicenses": "node ./generateLicenses.js && node ./scripts/generateLicenseBundle.js",
    "prepareFonts": "node ./scripts/prepareFontAssets.js",
    "capture": "node ./scripts/capture.js",
    "use:manifold:local": "node ./scripts/setManifoldSource.js local",
    "which:manifold": "node ./scripts/setManifoldSource.js"
  },
  "type": "module",
  "bin": {
    "brep-io-kernel": "./bin/brep-io-kernel.js"
  },
  "main": "./dist-kernel/brep-kernel.js",
  "module": "./dist-kernel/brep-kernel.js",
  "exports": {
    ".": "./dist-kernel/brep-kernel.js",
    "./BREP": "./dist-kernel/brep-kernel.js",
    "./PartHistory": "./dist-kernel/brep-kernel.js",
    "./AssemblyConstraintHistory": "./dist-kernel/brep-kernel.js",
    "./AssemblyConstraintRegistry": "./dist-kernel/brep-kernel.js",
    "./SketchSolver2D": "./src/SketchSolver2D.js",
    "./CAD": "./src/CAD.js",
    "./Sketcher2D": "./src/Sketcher2D.js",
    "./Sketcher2DUtils": "./src/Sketcher2DUtils.js"
  },
  "imports": {
    "#textToFace/fontUrlLoaders": "./src/features/textToFace/fontUrlLoaders.kernel.js"
  },
  "files": [
    "bin/**",
    "src/**",
    "dist/**",
    "dist-kernel/**",
    "README.md",
    "LICENSE.md"
  ],
  "keywords": [],
  "author": "",
  "license": "SEE LICENSE IN LICENSE.md",
  "dependencies": {
    "@dimforge/rapier3d": "^0.19.3",
    "@tarikjabiri/dxf": "^2.8.9",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "jszip": "^3.10.1",
    "monaco-editor": "^0.55.1",
    "pngjs": "^7.0.0",
    "tess2": "^1.0.0",
    "three": "^0.183.2",
    "three-mesh-bvh": "^0.9.9",
    "vhacd-js": "^0.0.1"
  },
  "description": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/mmiscool/BREP.io"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "eslint": "^9.39.3",
    "globals": "^16.5.0",
    "nodemon": "^3.1.14",
    "playwright": "^1.58.2",
    "vite": "^7.3.1",
    "vite-plugin-wasm": "^3.5.0"
  }
}
